<Window x:Class="GtaAdminReportsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GtaAdminReportsApp"
        mc:Ignorable="d"
        Title="GTA 5 Admin Reports Manager"
        Icon="docs/media/logo.jpg"
        Height="680"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel LastChildFill="False">
            <Image Source="docs/media/logo.jpg"
                   Width="54"
                   Height="54"
                   Stretch="UniformToFill"
                   Margin="0,0,12,0"/>
            <TextBlock VerticalAlignment="Center"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Text="Управление репортами FiveM"/>
        </DockPanel>

        <TabControl Grid.Row="1" Margin="0,16,0,0">
            <TabItem Header="Репорты">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <Button Content="Загрузить репорты"
                                Width="170"
                                Height="34"
                                Margin="0,0,8,0"
                                Click="LoadReports_Click"/>
                        <Button Content="Сортировать по классам"
                                Width="190"
                                Height="34"
                                Margin="0,0,8,0"
                                Click="SortReports_Click"/>
                        <Button Content="Сбросить демо-данные"
                                Width="190"
                                Height="34"
                                Margin="0,0,8,0"
                                Click="ResetDemoData_Click"/>
                        <Button Content="Заполнить 50 репортов"
                                Width="190"
                                Height="34"
                                Margin="0,0,8,0"
                                Click="AddFiftyReports_Click"/>
                        <TextBlock Text="Фильтр:"
                                   VerticalAlignment="Center"
                                   Margin="8,0,8,0"/>
                        <ComboBox Width="180"
                                  Height="30"
                                  ItemsSource="{Binding AdminClassFilterOptions}"
                                  SelectedItem="{Binding SelectedAdminClassFilter}"/>
                        <Button Content="Применить фильтр"
                                Width="150"
                                Height="34"
                                Margin="8,0,0,0"
                                Click="ApplyFilter_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FilteredReports}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Width="70" Binding="{Binding Id}"/>
                            <DataGridTextColumn Header="Игрок" Width="140" Binding="{Binding PlayerName}"/>
                            <DataGridTextColumn Header="Тип нарушения" Width="140" Binding="{Binding ViolationType}"/>
                            <DataGridTextColumn Header="Описание" Width="*" Binding="{Binding Description}"/>
                            <DataGridTextColumn Header="Приоритет" Width="90" Binding="{Binding Priority}"/>
                            <DataGridTextColumn Header="Класс администратора" Width="170" Binding="{Binding TargetAdminClass}"/>
                            <DataGridTextColumn Header="Статус" Width="110" Binding="{Binding Status}"/>
                            <DataGridTextColumn Header="Создан" Width="140" Binding="{Binding CreatedAt}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Логи">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,12">
                        <Button Content="Обновить логи"
                                Width="150"
                                Height="34"
                                Margin="0,0,8,0"
                                Click="RefreshLogs_Click"/>
                        <Button Content="Очистить логи"
                                Width="150"
                                Height="34"
                                Click="ClearLogs_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Logs}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Width="80" Binding="{Binding Id}"/>
                            <DataGridTextColumn Header="Уровень" Width="90" Binding="{Binding Level}"/>
                            <DataGridTextColumn Header="Действие" Width="140" Binding="{Binding Action}"/>
                            <DataGridTextColumn Header="Сообщение" Width="*" Binding="{Binding Message}"/>
                            <DataGridTextColumn Header="Детали" Width="220" Binding="{Binding Details}"/>
                            <DataGridTextColumn Header="Создано (UTC)" Width="160" Binding="{Binding CreatedAt}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Padding="12"
                Margin="0,12,0,0"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</Window>
